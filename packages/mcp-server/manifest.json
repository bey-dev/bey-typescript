{
  "dxt_version": "0.2",
  "name": "bey-mcp",
  "version": "0.1.0",
  "description": "The official MCP Server for the Beyond Presence API",
  "author": {
    "name": "Beyond Presence",
    "email": "support@beyondpresence.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bey-dev/bey-typescript.git"
  },
  "homepage": "https://github.com/bey-dev/bey-typescript/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.bey.dev",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "BEY_API_KEY": "${user_config.BEY_API_KEY}"
      }
    }
  },
  "user_config": {
    "BEY_API_KEY": {
      "title": "api_key",
      "description": "Your Beyond Presence API Key.",
      "required": true,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": [
    "api"
  ]
}
